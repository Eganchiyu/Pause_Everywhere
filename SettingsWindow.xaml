<Window x:Class="Pause_Everywhere.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置 - Pause Everywhere" Height="450" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F0F4F8">
    <Grid Margin="10">
        <Border CornerRadius="8" Background="White" Padding="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="功能设置" FontSize="22" FontWeight="Bold" Margin="10,0,0,10" Foreground="#333333"/>

                <TabControl Grid.Row="1" Margin="0,0,0,10">
                    <!-- 常规 -->
                    <TabItem Header="常规">
                        <StackPanel Margin="10">
                            <GroupBox Header="基础" Margin="0,0,0,10" Padding="10">
                                <StackPanel>
                                    <CheckBox x:Name="MuteCheckBox" Content="暂停时自动静音系统音量" Margin="0,5"/>
                                    <CheckBox x:Name="DimCheckBox" Content="环境过亮时自动压暗 (遮罩层)" Margin="0,5"/>
                                </StackPanel>
                            </GroupBox>
                            <Expander Header="高级性能参数 (开发者)" Margin="0,5">
                                <StackPanel Margin="10,5,0,0">
                                    <TextBlock Text="屏幕变化检测灵敏度" Foreground="Gray" FontSize="11"/>
                                    <Slider x:Name="ThresholdSlider" Minimum="5000" Maximum="50000" Value="20000" TickFrequency="1000" IsSnapToTickEnabled="True"/>
                                    <TextBlock Text="遮罩不透明度" Foreground="Gray" FontSize="11" Margin="0,10,0,0"/>
                                    <Slider x:Name="OpacitySlider" Minimum="0.1" Maximum="0.9" Value="0.25" TickFrequency="0.05" IsSnapToTickEnabled="True"/>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </TabItem>

                    <!-- 音效 -->
                    <TabItem Header="音效">
                        <StackPanel Margin="10">
                            <CheckBox x:Name="EnableStartSoundCheckBox" Content="启用启动音效" Margin="0,5"/>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="启动音效:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Grid.Column="1" x:Name="StartSoundPathText" Text="未选择" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <Button Grid.Column="2" Content="浏览..." Click="SelectStartSound_Click" Width="50" Margin="5,0,0,0"/>
                            </Grid>

                            <CheckBox x:Name="EnableEndSoundCheckBox" Content="启用结束音效" Margin="0,15,0,5"/>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="结束音效:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Grid.Column="1" x:Name="EndSoundPathText" Text="未选择" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <Button Grid.Column="2" Content="浏览..." Click="SelectEndSound_Click" Width="50" Margin="5,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </TabItem>

                    <!-- 图像 -->
                    <TabItem Header="图像">
                        <StackPanel Margin="10">
                            <CheckBox x:Name="EnableImageOverlayCheckBox" Content="启用自定义图像覆盖 (老板键)" Margin="0,5"/>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="选择图片:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Grid.Column="1" x:Name="ImagePathText" Text="未选择" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <Button Grid.Column="2" Content="浏览..." Click="SelectImage_Click" Width="50" Margin="5,0,0,0"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,5">
                                <TextBlock Text="填充模式:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <ComboBox x:Name="ImageFillModeComboBox" Width="120">
                                    <ComboBoxItem Content="None"/>
                                    <ComboBoxItem Content="Fill"/>
                                    <ComboBoxItem Content="Uniform"/>
                                    <ComboBoxItem Content="UniformToFill"/>
                                </ComboBox>
                            </StackPanel>
                            <TextBlock Text="图像透明度:" Margin="0,10,0,0"/>
                            <Slider x:Name="ImageOpacitySlider" Minimum="0.0" Maximum="1.0" Value="1.0" TickFrequency="0.1" IsSnapToTickEnabled="True"/>
                        </StackPanel>
                    </TabItem>

                    <!-- 文字 -->
                    <TabItem Header="文字">
                        <StackPanel Margin="10">
                            <CheckBox x:Name="EnableTextOverlayCheckBox" Content="启用自定义文字显示" Margin="0,5"/>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <TextBlock Text="显示文本:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBox x:Name="OverlayTextBox" Width="200" Text="PAUSE"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <TextBlock Text="字体大小:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBox x:Name="TextFontSizeTextBox" Width="50" Text="96"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <TextBlock Text="字体颜色:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <ComboBox x:Name="TextColorComboBox" Width="100">
                                    <ComboBoxItem Content="White" Tag="#FFFFFFFF"/>
                                    <ComboBoxItem Content="Black" Tag="#FF000000"/>
                                    <ComboBoxItem Content="Red" Tag="#FFFF0000"/>
                                    <ComboBoxItem Content="Green" Tag="#FF00FF00"/>
                                    <ComboBoxItem Content="Blue" Tag="#FF0000FF"/>
                                    <ComboBoxItem Content="Yellow" Tag="#FFFFFF00"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </TabItem>

                    <!-- 特效 -->
                    <TabItem Header="特效">
                        <StackPanel Margin="10">
                            <CheckBox x:Name="EnableAdvancedEffectsCheckBox" Content="启用高级屏幕特效" Margin="0,5"/>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <TextBlock Text="特效类型:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <ComboBox x:Name="EffectTypeComboBox" Width="150">
                                    <ComboBoxItem Content="黑白/灰度化 (Grayscale)"/>
                                    <ComboBoxItem Content="CRT 扫描线"/>
                                    <ComboBoxItem Content="赛博故障风 (Glitch)"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </TabItem>
                </TabControl>

                <Button Grid.Row="2" Content="保存并应用" Click="SaveButton_Click"
                        Height="35" Background="#0078D7" Foreground="White" FontWeight="Bold" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
